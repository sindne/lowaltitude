# 低空空域风险评估系统 - 环境配置示例文件
# 复制此文件为 .env 并填写实际的密钥配置

# ========================================
# 地图API密钥配置
# ========================================

# 高德地图API密钥
# 获取地址：https://lbs.amap.com/
AMAP_KEY=your_amap_api_key_here

# 百度地图API密钥（可选，备用API）
# 获取地址：https://lbsyun.baidu.com/
BAIDU_MAP_KEY=your_baidu_map_api_key_here

# 腾讯地图API密钥（可选，备用API）
# 获取地址：https://lbs.qq.com/
TENCENT_MAP_KEY=your_tencent_map_api_key_here

# ========================================
# 大模型API密钥配置
# ========================================

# DeepSeek API密钥
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_KEY=your_deepseek_api_key_here

# ========================================
# 其他API密钥配置（可选）
# ========================================

# 和风天气API密钥（可选，用于获取更详细的天气数据）
# 获取地址：https://dev.qweather.com/
# QWEATHER_KEY=your_qweather_api_key_here

# OpenAI API密钥（可选，备用模型）
# OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# 系统配置
# ========================================

# 服务器端口
PORT=5006

# 调试模式（开发环境设置为true，生产环境设置为false）
DEBUG=false

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# ========================================
# 数据库配置
# ========================================

# SQLite数据库文件路径（默认使用相对路径）
# DATABASE_PATH=./data/risk_assessment.db

# ========================================
# 模型配置
# ========================================

# 基础模型名称
BASE_MODEL_NAME=gpt2

# 模型输出目录
MODEL_OUTPUT_DIR=./local_models

# Hugging Face镜像源（国内用户推荐使用）
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=./hf_cache
TRANSFORMERS_CACHE=./hf_cache/transformers

# ========================================
# 缓存配置
# ========================================

# API缓存时间（秒）
API_CACHE_TTL=3600

# 是否启用缓存
ENABLE_CACHE=true
